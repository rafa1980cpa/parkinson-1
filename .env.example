# NeuroVida PRO — Variables de Entorno / Environment Variables
# ─────────────────────────────────────────────────────────────
# Copia este archivo como .env y rellena los valores reales.
# Copy this file as .env and fill in the real values.
# ─────────────────────────────────────────────────────────────

# ── SPOTIFY (Musicoterapia / Musicotherapy Hub) ───────────────
# Obtener en: https://developer.spotify.com/dashboard
# Create an App → copy Client ID → paste below
#
# NOTA: Esta app usa OAuth2 PKCE — el Client Secret NO se expone
# en el frontend. Solo el Client ID es necesario en el código.
#
# NOTE: This app uses OAuth2 PKCE — the Client Secret is NOT
# exposed on the frontend. Only the Client ID is needed.
SPOTIFY_CLIENT_ID=your_spotify_client_id_here

# El Client Secret es solo necesario si implementas un backend/proxy.
# The Client Secret is only needed if you implement a backend/proxy.
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here

# ── FIREBASE ──────────────────────────────────────────────────
# Configurar en: modules/firebase-config.js (no en .env)
# Los SDKs de Firebase se configuran con valores expuestos en el cliente.
# Configure in: modules/firebase-config.js (not in .env)
FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_STORAGE_BUCKET=your_project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your_sender_id
FIREBASE_APP_ID=your_app_id
